{
  "compilerOptions": {
      "alwaysStrict": true,
      "declaration": false,
      "rootDir": "src",
      "target": "ES2020",
      "lib": [
        "dom",
        "dom.iterable",
        "es2020"
      ],
      "allowJs": true,
      "skipLibCheck": true,
      "esModuleInterop": true,
      "allowSyntheticDefaultImports": true,
      "strict": true,
      "forceConsistentCasingInFileNames": true,
      "importHelpers": true,
      "module": "esnext",
      "moduleResolution": "bundler",
      "typeRoots": [
        "node_modules/@types"
      ],
      "resolveJsonModule": true,
      "ignoreDeprecations": "5.0",
      "isolatedModules": true,
      "noEmit": true,
      "noEmitHelpers": true,
      "jsx": "react-jsx",
      "noUnusedLocals": false, 
      "noUnusedParameters": false 
    },
    "include": [
      "src"
    ],
  "exclude": [
    "node_modules"
  ]
}
